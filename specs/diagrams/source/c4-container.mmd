graph TB
    subgraph "Digital Mao - Container View"
        subgraph "Client Layer"
            WebApp["⚛️ React Web App<br/>(TypeScript)<br/><br/>Game UI, chat interface,<br/>rule proposal forms"]
        end
        
        subgraph "Application Layer"
            GameServer["🎮 Game Server<br/>(Node.js/Express + Socket.io)<br/><br/>• REST APIs (Game, Rule Management)<br/>• WebSocket server (real-time events)<br/>• Message Log Manager<br/>• Event Queue<br/>• Dynamic Rules Engine"]
            
            LLMJudge["⚖️ LLM Judge Service<br/>(Python/FastAPI)<br/><br/>• Rule Compiler (NL → executable)<br/>• Action Evaluator<br/>• Penalty Decision Engine<br/>• Context Builder"]
        end
        
        subgraph "Data Layer"
            GameDB[("🗄️ Game State DB<br/>(PostgreSQL)<br/><br/>Transactional storage:<br/>• Games, players, cards<br/>• Actions, penalties<br/>• Chat messages<br/>• Active rules")]
            
            KnowledgeGraph[("🧠 Knowledge Graph<br/>(Neo4j)<br/><br/>LLM Judge context:<br/>• Enforcement cases<br/>• Precedents<br/>• Rule dependencies<br/>• Learning patterns")]
            
            Cache[("⚡ Redis<br/><br/>• Event queue<br/>• Active game sessions<br/>• WebSocket connections")]
        end
    end
    
    subgraph "External Services"
        LLM["🤖 LLM API<br/>(OpenAI GPT-4 or<br/>Anthropic Claude)<br/><br/>Natural language<br/>understanding"]
        Auth["🔐 Auth Service<br/>(OAuth 2.0)"]
    end
    
    %% Client connections
    WebApp -->|"REST API<br/>[HTTPS/JSON]<br/>Game & Rule Management"| GameServer
    WebApp -->|"WebSocket<br/>[WSS]<br/>Real-time events & chat"| GameServer
    
    %% Game Server connections
    GameServer -->|"Reads/Writes<br/>Transactional"| GameDB
    GameServer -->|"Pub/Sub<br/>Event queue"| Cache
    GameServer -->|"Requests<br/>Rule compilation<br/>& evaluation"| LLMJudge
    GameServer -->|"Authenticates<br/>users"| Auth
    
    %% LLM Judge connections
    LLMJudge -->|"Stores<br/>enforcement cases<br/>& precedents"| KnowledgeGraph
    LLMJudge -->|"NL processing<br/>& generation"| LLM
    
    %% Styling
    style WebApp fill:#61DAFB,stroke:#20232A,stroke-width:3px,color:#000
    style GameServer fill:#68A063,stroke:#3C5F3A,stroke-width:3px,color:#fff
    style LLMJudge fill:#009688,stroke:#00695C,stroke-width:3px,color:#fff
    style GameDB fill:#336791,stroke:#1A3A5C,stroke-width:2px,color:#fff
    style KnowledgeGraph fill:#4CAF50,stroke:#2E7D32,stroke-width:2px,color:#fff
    style Cache fill:#DC382D,stroke:#A82A21,stroke-width:2px,color:#fff
    style LLM fill:#FF6B6B,stroke:#CC5555,stroke-width:2px,color:#fff
    style Auth fill:#FFA500,stroke:#CC8400,stroke-width:2px,color:#fff